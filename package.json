{
  "name": "yocim-nexus",
  "private": true,
  "version": "0.1.2",
  "description": "YOCIM NEXUS - A modern multi-tab browser built with Electron",
  "author": "YOCIM",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:build": "vite build --mode electron && electron-builder --dir"
  },
  "build": {
    "appId": "com.yocim.browser",
    "productName": "YOCIM NEXUS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": "public/icon/app.png"
    },
    "mac": {
      "icon": "public/icon/app.png"
    },
    "protocols": [
      {
        "name": "HTTP",
        "schemes": ["http"]
      },
      {
        "name": "HTTPS",
        "schemes": ["https"]
      }
    ],
    "fileAssociations": [
      { "ext": "html", "name": "HTML Document", "role": "Viewer" },
      { "ext": "htm", "name": "HTM Document", "role": "Viewer" },
      { "ext": "xhtml", "name": "XHTML Document", "role": "Viewer" },
      { "ext": "svg", "name": "SVG Image", "role": "Viewer" },
      { "ext": "xml", "name": "XML Document", "role": "Viewer" },
      { "ext": "txt", "name": "Text Document", "role": "Viewer" },
      { "ext": "pdf", "name": "PDF Document", "role": "Viewer" },
      { "ext": "mht", "name": "Web Archive", "role": "Viewer" },
      { "ext": "webp", "name": "WebP Image", "role": "Viewer" },
      { "ext": "png", "name": "PNG Image", "role": "Viewer" },
      { "ext": "jpg", "name": "JPEG Image", "role": "Viewer" },
      { "ext": "jpeg", "name": "JPEG Image", "role": "Viewer" },
      { "ext": "gif", "name": "GIF Image", "role": "Viewer" },
      { "ext": "bmp", "name": "BMP Image", "role": "Viewer" },
      { "ext": "mp4", "name": "MP4 Video", "role": "Viewer" },
      { "ext": "webm", "name": "WebM Video", "role": "Viewer" }
    ]
  },
  "dependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^42.2.0",
    "electron-builder": "^26.11.1",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^1.0.0-beta.13",
    "vite-plugin-electron-renderer": "^1.0.0-beta.9"
  }
}
